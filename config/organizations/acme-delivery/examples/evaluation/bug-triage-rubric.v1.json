{
  "rubric_version": 1,
  "fixture_kind": "evaluation-example",
  "applies_to": {
    "corpus_version": 1,
    "baseline_path": "cases[].human_reference"
  },
  "human_baseline": {
    "method": "independent-review-with-consensus",
    "reviewers_required": 2,
    "independent_first_pass": true,
    "resolution": "consensus-or-third-reviewer-adjudication",
    "frozen_before_evaluation_runs": true,
    "reviewer_identities_in_fixture": false
  },
  "score_scale": {
    "minimum": 0.0,
    "maximum": 1.0,
    "higher_is_better": true
  },
  "dimensions": [
    {
      "id": "severity",
      "weight": 0.35,
      "prediction_field": "severity",
      "reference_field": "severity",
      "scorer": "ordinal-distance",
      "ordered_labels": [
        "low",
        "medium",
        "high",
        "critical"
      ],
      "distance_scores": {
        "0": 1.0,
        "1": 0.5,
        "2_or_more": 0.0
      }
    },
    {
      "id": "missing-information",
      "weight": 0.35,
      "prediction_field": "missing_information",
      "reference_field": "missing_information",
      "scorer": "set-f1",
      "label_matching": "canonical-slug-exact",
      "duplicate_handling": "collapse",
      "both_sets_empty_score": 1.0,
      "one_set_empty_score": 0.0,
      "formula": "2 * precision * recall / (precision + recall)"
    },
    {
      "id": "decision",
      "weight": 0.30,
      "prediction_field": "decision",
      "reference_field": "expected_decision",
      "scorer": "exact-match",
      "allowed_labels": [
        "report",
        "escalation"
      ],
      "match_score": 1.0,
      "mismatch_score": 0.0
    }
  ],
  "aggregation": {
    "case_score": "weighted-arithmetic-mean",
    "corpus_score": "unweighted-macro-mean-of-case-scores",
    "rounding": "none-until-presentation",
    "unscored_reference_fields": [
      "expected_routing"
    ]
  }
}
