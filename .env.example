# Local Docker Compose defaults only. Copy this file to `.env` before starting
# HIVE. Never reuse these credentials outside a local development environment.
POSTGRES_USER=hive
POSTGRES_PASSWORD=hive
POSTGRES_DB=hive

# Required only by the real-provider demo overrides. Copy this file to `.env`
# and set the secret locally; never commit a populated `.env` file.
OPENAI_API_KEY=
# Optional. The demo overrides use gpt-5-mini when this remains unset.
OPENAI_MODEL_ID=
